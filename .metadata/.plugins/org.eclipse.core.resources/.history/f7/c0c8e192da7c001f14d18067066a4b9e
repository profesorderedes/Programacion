		long dato = 656787638736328L;

		double decimal = 0.6547;
		float flotante = 0.6547F;

		boolean bueno = true;
		boolean malo = false;

		char signo = '@';

		System.out.println(numero);
		System.out.println(dada);
		System.out.println(cifra);
