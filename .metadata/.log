package ejercicios;

public class Ejer08 {
	public static void main(String[] args) {
		System.out.println(intMax(10, 5));
		System.out.println(intMin(10, 5));
	}

	static int intMax(int num1, int num2) {
		
		int numMax = 0;
		if (num1 > num2) {
			numMax = num1;
		} else (num1 < num2) {
			numMax = num2;
		} 

		return numMax;

	}

	static int intMin(int num, int num2) {
		int numMin = 0;
		if (num < num2) {
			numMin = num;
		} else if (num > num2) {
			numMin = num2;
		} else {
			numMin = 0;
		}

		return numMin;

	}

}
